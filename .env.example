# FRED API Anahtarı (https://fred.stlouisfed.org adresinden alınır)
FRED_API_KEY=BURAYA_FRED_API_ANAHTARINIZI_YAZIN

# Interactive Brokers (IBKR) Bağlantı Ayarları
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1
